                                        <iconPacks:PackIconSimpleIcons Kind="BuyMeACoffee"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                        Width="18"
                                                                        Height="18"
                                                                        VerticalAlignment="Center"
                                                                        Margin="10,0,0,0"
                                                                        Grid.Column="0" />

                                        <TextBlock Text="Buy Me A Coffee"
                                                       Foreground="{DynamicResource SecondaryAccent.Brush.WA100}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Grid.Column="1"
                                                       Margin="0,0,18,0" />
                                    </Grid>
