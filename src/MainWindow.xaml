                                    <Button.Resources>
                                        <SolidColorBrush x:Key="MahApps.Brushes.Gray10" Color="{StaticResource Alr.Colors.Red20}" />
                                        <SolidColorBrush x:Key="MahApps.Brushes.Gray8" Color="{StaticResource Alr.Colors.Red40}" />
