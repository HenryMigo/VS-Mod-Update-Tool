                            <TextBlock Grid.Row="1"
                                       Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                                       FontSize="12"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,15"
                                       Padding="25,10,25,10"
                                       Text="Welcome to the information panel. This list is intentionally short because everything else in the app should be entirely self-explanatory. This space is just reserved for the occasional feature that might benefit from a tiny bit of extra context." />

                            <Separator Grid.Row="2" Background="{StaticResource MahApps.Brushes.Accent3}" Margin="0,10,0,25" />

                            <!-- Version Mismatch Explanation -->
                            <StackPanel Grid.Row="3" Margin="10,0,10,50">
                                <TextBlock Text="Version Mismatch"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="An update is available, but the author hasn't explicitly tagged it for your selected game version.&#x0a;&#x0a;You'll see this most often right after a major game update, when mod authors haven't yet updated their version tags.&#x0a;&#x0a;Because many mods work perfectly fine on newer game versions without changes, this feature ensures you don't miss out on those files. However, instead of blindly installing them and risking a broken setup, the tool flags these mismatches and requires a manual update so you can proceed with caution."
                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                                           TextAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.8"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Mod Browser Explanation -->
                            <StackPanel Grid.Row="4" Margin="10,0,10,50">
                                <TextBlock Text="Mod Browser"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="The mod browser introduces an embedded tool called WebView2, which essentially runs a lightweight Chromium browser window inside the app. Because of this, you may notice slightly higher memory usage when the browser is active, though testing shows it typically sits at around 150MB of RAM.&#x0a;&#x0a;Please note that while the browser gives you full access to the mod repository, it operates independently from the app's version filtering.&#x0a;&#x0a;It will not automatically restrict search results to your targeted game version, so you will need to manually ensure you are downloading the correct file version for your game."
                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                                           TextAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.8"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </mah:Flyout>

