<mah:MetroWindow x:Class="VSSuite.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:converters="clr-namespace:VSSuite.Resources.Functions.Converters"
                 xmlns:viewmodels="clr-namespace:VSSuite.Resources.ViewModels"
                 xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
                 xmlns:local="clr-namespace:VSSuite"
                 d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
                 Title="{Binding AppVersion, RelativeSource={RelativeSource Self}, StringFormat='VSSuite {0}'}"
                 MinHeight="880"
                 MinWidth="1293"
                 Height="880"
                 Width="1293"
                 FontFamily="Segoe UI"
                 GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                 NonActiveGlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                 WindowStyle="SingleBorderWindow"
                 ResizeMode="CanResizeWithGrip"
                 mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:StringNotNullOrEmptyToVisibilityConverter x:Key="StringToVisibility" />
        <converters:VersionToColorConverter x:Key="VersionToColorConverter" />

        <SolidColorBrush x:Key="MahApps.Brushes.Gray3" Color="{DynamicResource MahApps.Colors.Accent3}" />
        <SolidColorBrush x:Key="MahApps.Brushes.Thumb" Color="{DynamicResource MahApps.Colors.Accent2}" />
    </Window.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Click="OpenGithubRepo_Click" ToolTip="Open the GitHub repo">
                <iconPacks:PackIconSimpleIcons Width="22" Height="22" Kind="GitHub" />
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>

            <!-- Mod Searchbar -->
            <Border Background="{DynamicResource PrimaryAccent.Brush.W500}"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Height="22"
                    Width="300"
                    Margin="10,0,10,0"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Magnify"
                                                Width="12"
                                                Height="12"
                                                Grid.Column="0"
                                                Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0" />

                    <TextBox x:Name="ModSearchTextBox"
                             Grid.Column="1"
                             VerticalAlignment="Center"
                             TextAlignment="Left"
                             Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="5,0,2,0"
                             TextChanged="Searchbar_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <TextBlock x:Name="WatermarkPlaceholder"
                                                           Text="Search mods..."
                                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA400.O80}"
                                                           FontSize="11"
                                                           Visibility="Collapsed"
                                                           IsHitTestVisible="False"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0" />

                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                                            </Grid>

                                            <ControlTemplate.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="" />
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="WatermarkPlaceholder" Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Grid.Column="2"
                            Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                            Padding="2"
                            Height="18"
                            Width="18"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Click="ClearSearch_Click">
                        <iconPacks:PackIconMaterial Width="10" Height="10" Kind="Close" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Title Bar Buttons / Leaving this here so I don't have to remake it if I use it again -->
            <!--<Button Click="OpenBuyMeACoffee_Click">
                <iconPacks:PackIconSimpleIcons Width="22" Height="22" Kind="Buymeacoffee">
                    <iconPacks:PackIconSimpleIcons.ToolTip>
                        <TextBlock>
                            <Run Text="Buy Me a Coffee" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                            <LineBreak />
                            <Run Text="If you like my work, consider buying me a coffee." />
                        </TextBlock>
                    </iconPacks:PackIconSimpleIcons.ToolTip>
                </iconPacks:PackIconSimpleIcons>
            </Button>-->
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <mah:SplitView x:Name="SplitView" DisplayMode="CompactOverlay" IsPaneOpen="False" CompactPaneLength="50" OpenPaneLength="250" PaneBackground="Transparent">
            <mah:SplitView.Pane>
                <!-- Sidebar Navigation -->
                <Border BorderBrush="{DynamicResource MahApps.Brushes.Accent3}" BorderThickness="0 0 1 0">
                    <mah:HamburgerMenu Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                       IsPaneOpen="{Binding IsPaneOpen, ElementName=SplitView, Mode=TwoWay}" CompactPaneLength="50" OpenPaneLength="250"
                                       PaneBackground="{StaticResource SecondaryAccent.Brush.W500}" Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                       HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                       Background="Transparent" Width="250"

                                       ItemTemplate="{DynamicResource MenuTemplate}"
                                       ItemContainerStyle="{DynamicResource ItemStyle}"
                                       ItemsSource="{Binding MenuItems}"

                                       OptionsItemTemplate="{DynamicResource MenuTemplate}"
                                       OptionsItemContainerStyle="{DynamicResource ItemStyle}"
                                       OptionsItemsSource="{Binding OptionsMenuItems}">

                        <mah:HamburgerMenu.Resources>
                            <SolidColorBrush x:Key="MahApps.HamburgerMenu.Pane.Foreground" Color="{DynamicResource SecondaryAccent.Colors.WA400}" />

                            <DataTemplate x:Key="MenuTemplate">
                                <Button Command="{Binding Command}"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{TemplateBinding Background}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <iconPacks:PackIconMaterial Width="25" Height="25"
                                                                            Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                                                            Kind="{Binding Icon}"
                                                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                            Margin="12,10,10,10" Grid.Column="0">
                                                    <iconPacks:PackIconMaterial.ToolTip>
                                                        <TextBlock><Run Text="{Binding Text}" /></TextBlock>
                                                    </iconPacks:PackIconMaterial.ToolTip>
                                                </iconPacks:PackIconMaterial>

                                                <TextBlock Text="{Binding Text}"
                                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                                           FontSize="16" FontWeight="Bold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Left"
                                                           Margin="5,10,10,10" Grid.Column="1" />
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>

                            <Style x:Key="ItemStyle" TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="Padding" Value="5" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RootGrid" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </mah:HamburgerMenu.Resources>
                    </mah:HamburgerMenu>
                </Border>
            </mah:SplitView.Pane>

            <mah:SplitView.Content>
                <!-- Main Content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- Top Bar 0 -->
                    <Grid Grid.Row="0" Background="{StaticResource SecondaryAccent.Brush.W500}">
                        <Border BorderBrush="{DynamicResource MahApps.Brushes.Accent3}" BorderThickness="1 1 0 1">
                            <Grid Height="35" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Folder Path -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Column="0">
                                    <Border Background="{DynamicResource PrimaryAccent.Brush.W500}"
                                            BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Width="760"
                                            Height="35"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <iconPacks:PackIconMaterial Kind="FolderOpenOutline"
                                                                        Width="14"
                                                                        Height="14"
                                                                        Grid.Column="0"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                        VerticalAlignment="Center"
                                                                        Margin="8,0,0,0" />

                                            <!-- TextBox -->
                                            <TextBox x:Name="ModsFolderTextBox"
                                                     Grid.Column="1"
                                                     IsReadOnly="True"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Left"
                                                     Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Margin="5,0,5,0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="OverridesDefaultStyle" Value="True" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <ScrollViewer x:Name="PART_ContentHost" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <!-- Buttons -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,2,0">
                                                <!-- Browse Button -->
                                                <Button Click="BrowseFolder_Click"
                                                        Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                                        Padding="4"
                                                        Height="26" Width="26">
                                                    <iconPacks:PackIconMaterial Width="18" Height="18" Kind="FolderOpen" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}">
                                                        <iconPacks:PackIconMaterial.ToolTip>
                                                            <TextBlock>
                                                                <Run Text="Browse for a mods folder" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                                <LineBreak />
                                                                <Run Text="Open the folder browser dialog to select a new mods folder." />
                                                            </TextBlock>
                                                        </iconPacks:PackIconMaterial.ToolTip>
                                                    </iconPacks:PackIconMaterial>
                                                </Button>
                                                <!-- Refresh Button -->
                                                <Button Click="RefreshMods_Click"
                                                        Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                                        Padding="4"
                                                        Height="26" Width="26">
                                                    <iconPacks:PackIconMaterial Width="18" Height="18" Kind="FolderRefresh" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}">
                                                        <iconPacks:PackIconMaterial.ToolTip>
                                                            <TextBlock>
                                                                <Run Text="Refresh mods folder" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                                <LineBreak />
                                                                <Run Text="Refresh the current mods folder to check for any new or removed files." />
                                                            </TextBlock>
                                                        </iconPacks:PackIconMaterial.ToolTip>
                                                    </iconPacks:PackIconMaterial>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Game Version Dropdown -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Margin="0 0 5 0">
                                    <ComboBox x:Name="GameVersionDropdown"
                                              Width="210"
                                              Height="35"
                                              mah:ControlsHelper.CornerRadius="2"
                                              Background="{DynamicResource PrimaryAccent.Brush.W500}"
                                              BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                                              Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                              VerticalAlignment="Center"
                                              BorderThickness="1"
                                              VerticalContentAlignment="Center">

                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Border.MouseOver" Color="{DynamicResource MahApps.Colors.Accent2}" />
                                            <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Border.Focus" Color="{DynamicResource MahApps.Colors.Accent3}" />
                                            <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.PopupBorder" Color="{DynamicResource MahApps.Colors.Accent3}" />
                                            <SolidColorBrush x:Key="MahApps.Brushes.Gray1" Color="{StaticResource MahApps.Colors.Accent}" />
                                            <SolidColorBrush x:Key="MahApps.Brushes.Gray5" Color="{StaticResource MahApps.Colors.Accent3}" />
                                        </ComboBox.Resources>

                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>

                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                <Setter Property="Tag" Value="InDropDown" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ComboBox.ItemContainerStyle>

                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid x:Name="ItemRoot" VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition x:Name="IconCol" Width="Auto" />
                                                        <ColumnDefinition x:Name="TextCol" Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon -->
                                                    <iconPacks:PackIconMaterial x:Name="HeaderIcon"
                                                                                Kind="ClockOutline"
                                                                                Width="14" Height="14"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                                Margin="4,0,8,0" />

                                                    <!-- Text -->
                                                    <TextBlock x:Name="HeaderText"
                                                               Text="Game Version:"
                                                               Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                                               Margin="0,0,10,0" />

                                                    <!-- Pill -->
                                                    <Border x:Name="VersionPill"
                                                            Grid.Column="2"
                                                            BorderBrush="{DynamicResource Alr.Brushes.GreenBase}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="8,2,8,2"
                                                            Background="{DynamicResource Alr.Brushes.Green20}"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SecondaryAccent.Brush.WA100}" />
                                                    </Border>
                                                </Grid>

                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ComboBoxItem}}, Path=Tag}" Value="InDropDown">
                                                        <Setter TargetName="HeaderIcon" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="VersionPill" Property="Background" Value="#33888888" />
                                                        <Setter TargetName="VersionPill" Property="BorderBrush" Value="#66888888" />
                                                        <Setter TargetName="VersionPill" Property="HorizontalAlignment" Value="Center" />
                                                        <Setter TargetName="VersionPill" Property="Margin" Value="0" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Top Bar 1 -->
                    <Grid Grid.Row="1" Background="{StaticResource PrimaryAccent.Brush.W500}">
                        <Border BorderBrush="{StaticResource MahApps.Brushes.Accent3}" BorderThickness="1 0 0 1">
                            <Grid Height="35" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Pill Indicators -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                                    <StackPanel.Resources>
                                        <!-- Border Style -->
                                        <Style x:Key="StatusPillStyle" TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.SemiTransparent}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent3}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="12" />
                                            <Setter Property="Padding" Value="10,2,10,2" />
                                            <Setter Property="Margin" Value="0,0,10,0" />
                                            <Setter Property="Height" Value="24" />
                                        </Style>
                                        <!-- Text Style -->
                                        <Style x:Key="PillTextStyle" TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="12" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryAccent.Brush.WA400}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                        <!-- Status Dot Style -->
                                        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
                                            <Setter Property="Width" Value="8" />
                                            <Setter Property="Height" Value="8" />
                                            <Setter Property="Margin" Value="0,0,8,0" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- Total Mods Pill -->
                                    <Border Style="{StaticResource StatusPillStyle}" BorderBrush="{DynamicResource MahApps.Brushes.Accent3}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Style="{StaticResource StatusDotStyle}" Fill="{DynamicResource MahApps.Brushes.Gray6}" />
                                            <TextBlock Text="Total Mods:" Style="{StaticResource PillTextStyle}" Margin="0,0,5,0" />
                                            <TextBlock x:Name="TotalModsCountText" Text="0" Style="{StaticResource PillTextStyle}" Foreground="{DynamicResource MahApps.Brushes.Gray6}" FontWeight="Bold" />
                                        </StackPanel>
                                        <Border.ToolTip>
                                            <TextBlock>
                                                <Run Text="Total Mods" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                <LineBreak />
                                                <Run Text="The total number of mods detected in your current directory." />
                                            </TextBlock>
                                        </Border.ToolTip>
                                    </Border>

                                    <!-- Updates Disabled Pill -->
                                    <Border Style="{StaticResource StatusPillStyle}" BorderBrush="{DynamicResource MahApps.Brushes.Accent3}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Style="{StaticResource StatusDotStyle}" Fill="{DynamicResource Alr.Brushes.RedBase}" />
                                            <TextBlock Text="Updates Disabled:" Style="{StaticResource PillTextStyle}" Margin="0,0,5,0" />
                                            <TextBlock x:Name="DisabledCountText" Text="0" Style="{StaticResource PillTextStyle}" Foreground="{DynamicResource Alr.Brushes.RedBase}" FontWeight="Bold" />
                                        </StackPanel>
                                        <Border.ToolTip>
                                            <TextBlock>
                                                <Run Text="Updates Disabled" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                <LineBreak />
                                                <Run Text="The number of mods excluded from update checks." />
                                            </TextBlock>
                                        </Border.ToolTip>
                                    </Border>

                                    <!-- Global Updates Available Pill -->
                                    <Border Style="{StaticResource StatusPillStyle}" BorderBrush="{DynamicResource MahApps.Brushes.Accent3}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Style="{StaticResource StatusDotStyle}" Fill="{DynamicResource Alr.Brushes.YellowBase}" />
                                            <TextBlock Text="Version Mismatch:" Style="{StaticResource PillTextStyle}" Margin="0,0,5,0" />
                                            <TextBlock x:Name="VersionMismatchCountText" Text="0" Style="{StaticResource PillTextStyle}" Foreground="{DynamicResource Alr.Brushes.YellowBase}" FontWeight="Bold" />
                                        </StackPanel>
                                        <Border.ToolTip>
                                            <TextBlock>
                                                <Run Text="Version Mismatch" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                <LineBreak />
                                                <Run Text="Updates are available, but they aren't explicitly marked for your selected game version. They are usually safe to install, but proceed with caution." />
                                            </TextBlock>
                                        </Border.ToolTip>
                                    </Border>

                                    <!-- Updates Available Pill -->
                                    <Border Style="{StaticResource StatusPillStyle}" BorderBrush="{DynamicResource MahApps.Brushes.Accent3}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Style="{StaticResource StatusDotStyle}" Fill="{DynamicResource Alr.Brushes.GreenBase}" />
                                            <TextBlock Text="Updates Available:" Style="{StaticResource PillTextStyle}" Margin="0,0,5,0" />
                                            <TextBlock x:Name="UpdateCountText" Text="0" Style="{StaticResource PillTextStyle}" Foreground="{DynamicResource Alr.Brushes.GreenBase}" FontWeight="Bold" />
                                        </StackPanel>
                                        <Border.ToolTip>
                                            <TextBlock>
                                                <Run Text="Updates Available" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                <LineBreak />
                                                <Run Text="Mods with available updates that match your selected game version." />
                                            </TextBlock>
                                        </Border.ToolTip>
                                    </Border>
                                </StackPanel>

                                <!-- Check for Updates Button -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                                    <Button x:Name="CheckUpdatesButton"
                                            Width="180"
                                            Height="35"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0 0 5 0"
                                            Click="CheckUpdatesButton_Click">

                                        <Button.Resources>
                                            <SolidColorBrush x:Key="MahApps.Brushes.Gray10" Color="{StaticResource PrimaryAccent.Colors.Accent}" />
                                            <SolidColorBrush x:Key="MahApps.Brushes.Gray8" Color="{StaticResource MahApps.Colors.Accent4}" />
                                        </Button.Resources>

                                        <Grid HorizontalAlignment="Stretch" Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <iconPacks:PackIconMaterial Kind="Update"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                        Width="18"
                                                                        Height="18"
                                                                        VerticalAlignment="Center"
                                                                        Margin="10,0,0,0"
                                                                        Grid.Column="0" />

                                            <TextBlock Text="Check for Updates"
                                                       Foreground="{DynamicResource SecondaryAccent.Brush.WA100}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Grid.Column="1"
                                                       Margin="0,0,18,0" />
                                        </Grid>
                                    </Button>
                                </StackPanel>

                                <!-- Update All Button -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2">
                                    <Button x:Name="UpdateAllModsButton"
                                            Width="180"
                                            Height="35"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0 0 5 0"
                                            Click="UpdateAllModsButton_Click">

                                        <Button.Resources>
                                            <SolidColorBrush x:Key="MahApps.Brushes.Gray10" Color="{StaticResource PrimaryAccent.Colors.Accent}" />
                                            <SolidColorBrush x:Key="MahApps.Brushes.Gray8" Color="{StaticResource MahApps.Colors.Accent3}" />
                                        </Button.Resources>

                                        <Grid HorizontalAlignment="Stretch" Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <iconPacks:PackIconMaterial Kind="Download"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                        Width="18"
                                                                        Height="18"
                                                                        VerticalAlignment="Center"
                                                                        Margin="10,0,0,0"
                                                                        Grid.Column="0" />

                                            <TextBlock Text="Update All"
                                                       Foreground="{DynamicResource SecondaryAccent.Brush.WA100}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Grid.Column="1"
                                                       Margin="0,0,18,0" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Mods Table Section -->
                    <Grid Grid.Row="3">
                        <Border BorderBrush="{StaticResource MahApps.Brushes.Accent3}" BorderThickness="1 0 0 0" Background="{StaticResource PrimaryAccent.Brush.W500}">
                            <!-- Mods Table -->
                            <DataGrid x:Name="ModsDataGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      CanUserAddRows="False"
                                      Margin="0,0,0,10"
                                      RowHeight="40"
                                      ColumnHeaderHeight="45"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch">

                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="MahApps.Brushes.Gray5" Color="{StaticResource MahApps.Colors.Accent4}" />
                                    <SolidColorBrush x:Key="MahApps.Brushes.Gray2" Color="{StaticResource SecondaryAccent.Colors.WA400}" />
                                    <SolidColorBrush x:Key="MahApps.Brushes.DataGridColumnHeader.SortArrowFill" Color="{StaticResource SecondaryAccent.Colors.WA400}" />

                                    <Style TargetType="{x:Type DataGridColumnHeader}"
                                           x:Key="CustomCenteredHeader"
                                           BasedOn="{StaticResource CenteredMetroColumnHeader}">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="{StaticResource MahApps.Brushes.Accent3}" />
                                        <Setter Property="Background" Value="{StaticResource SecondaryAccent.Brush.W500}" />
                                        <Setter Property="Foreground" Value="{StaticResource SecondaryAccent.Brush.WA400}" />
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.ColumnHeaderStyle>
                                    <StaticResource ResourceKey="CustomCenteredHeader" />
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridRow">
                                                    <DataGridCellsPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn x:Name="IgnoreColumn" Header="Ignore" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding DisableUpdate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Checked="DisableUpdateCheckBox_Changed"
                                                          Unchecked="DisableUpdateCheckBox_Changed"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center">
                                                    <CheckBox.Resources>
                                                        <SolidColorBrush x:Key="MahApps.Brushes.Highlight" Color="{DynamicResource Alr.Colors.RedBase}" />
                                                        <SolidColorBrush x:Key="MahApps.Brushes.CheckBox" Color="{DynamicResource MahApps.Colors.Accent3}" />
                                                        <SolidColorBrush x:Key="MahApps.Brushes.CheckBox.MouseOver" Color="{DynamicResource MahApps.Colors.Accent2}" />
                                                    </CheckBox.Resources>
                                                </CheckBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn x:Name="ModPagesColumn" Header="Mod Page" MinWidth="80" MaxWidth="80" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                                        Width="25" Height="25"
                                                        Click="OpenModPage_Click"
                                                        Visibility="{Binding ModPageUrl, Converter={StaticResource StringToVisibility}}">
                                                    <iconPacks:PackIconMaterial Width="22" Height="22" Kind="Web" Foreground="#68B1FF">
                                                        <iconPacks:PackIconMaterial.ToolTip>
                                                            <TextBlock>
                                                                <Run Text="Open the" FontStyle="Italic" />
                                                                <Run Text="{Binding Name}" FontWeight="Bold" FontStyle="Italic" />
                                                                <Run Text="mod page in your browser" FontStyle="Italic" />
                                                                <LineBreak />
                                                                <Run Text="{Binding ModPageUrl}" Foreground="#50A4FF" />
                                                            </TextBlock>
                                                        </iconPacks:PackIconMaterial.ToolTip>
                                                    </iconPacks:PackIconMaterial>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn x:Name="FileNameColumn" Header="File Name" Foreground="{DynamicResource SecondaryAccent.Brush.WA400}" Binding="{Binding FileName}" MinWidth="225" Width="*" ElementStyle="{DynamicResource CenterCellTextBlockStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Mod Name" Binding="{Binding Name}" Foreground="{DynamicResource SecondaryAccent.Brush.WA100}" MinWidth="225" Width="*" ElementStyle="{DynamicResource CenterCellTextBlockStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn x:Name="GameVersionColumn" Header="Game Version" Binding="{Binding Game}" Foreground="{DynamicResource SecondaryAccent.Brush.WA400}" MinWidth="125" Width="*" ElementStyle="{DynamicResource CenterCellTextBlockStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Installed Version" Binding="{Binding Version}" Foreground="{DynamicResource SecondaryAccent.Brush.WA400}" MinWidth="125" Width="*" ElementStyle="{DynamicResource CenterCellTextBlockStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Latest Version" MinWidth="125" Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterCellTextBlockStyle}">
                                                <Setter Property="Text" Value="{Binding LatestVersion}" />
                                                <Setter Property="Foreground">
                                                    <Setter.Value>
                                                        <MultiBinding Converter="{StaticResource VersionToColorConverter}">
                                                            <Binding BindingGroupName="Version" Path="Version" />
                                                            <Binding BindingGroupName="LatestVersion" Path="LatestVersion" />
                                                            <Binding BindingGroupName="HasVersionMismatch" Path="HasVersionMismatch" />
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Update" MinWidth="100" Width="*" SortMemberPath="HasUpdate" IsReadOnly="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                                        Width="40" Height="30"
                                                        Click="UpdateModButton_Click"
                                                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">

                                                    <iconPacks:PackIconMaterial Width="22" Height="22" Kind="Download">
                                                        <iconPacks:PackIconMaterial.Foreground>
                                                            <MultiBinding Converter="{StaticResource VersionToColorConverter}">
                                                                <Binding Path="Version" />
                                                                <Binding Path="LatestVersion" />
                                                                <Binding Path="HasVersionMismatch" />
                                                            </MultiBinding>
                                                        </iconPacks:PackIconMaterial.Foreground>

                                                        <iconPacks:PackIconMaterial.ToolTip>
                                                            <TextBlock>
                                                                <Run Text="Update Mod" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                                <LineBreak />
                                                                <Run Text="Update a single mod." />
                                                            </TextBlock>
                                                        </iconPacks:PackIconMaterial.ToolTip>
                                                    </iconPacks:PackIconMaterial>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </mah:SplitView.Content>
        </mah:SplitView>
    </Grid>

    <!-- Flyouts Section -->
    <mah:MetroWindow.Flyouts>
        <mah:FlyoutsControl>
            <!-- App Settings Flyout -->
            <mah:Flyout x:Name="AppSettingsFlyout"
                        Header="App Settings"
                        Position="Left"
                        Width="450"
                        Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                        Background="{StaticResource PrimaryAccent.Brush.W500}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                        BorderThickness="0 0 1 0"
                        IsOpen="{Binding IsAppSettingsFlyoutOpen}">

                <mah:Flyout.Resources>
                    <SolidColorBrush x:Key="MahApps.Brushes.Gray3" Color="{DynamicResource MahApps.Colors.Accent3}" />
                    <SolidColorBrush x:Key="MahApps.Brushes.Thumb" Color="{DynamicResource MahApps.Colors.Accent2}" />

                    <Style TargetType="{x:Type ScrollViewer}" BasedOn="{StaticResource MahApps.Styles.ScrollViewer}">
                        <Style.Resources>
                            <SolidColorBrush x:Key="MahApps.Brushes.Gray3" Color="{DynamicResource MahApps.Colors.Accent3}" />
                            <SolidColorBrush x:Key="MahApps.Brushes.Thumb" Color="{DynamicResource MahApps.Colors.Accent2}" />
                        </Style.Resources>
                    </Style>
                </mah:Flyout.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20,10,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Separator Grid.Row="0" Background="{StaticResource MahApps.Brushes.Accent3}" Margin="0,10,0,20" />

                            <!-- General Section -->
                            <TextBlock Grid.Row="1" Text="General" Foreground="{DynamicResource DarkOlive.Brush.WA700}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15" />

                            <!-- Default Game Version Dropdown -->
                            <Grid Grid.Row="2" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,50,0">
                                    <TextBlock Text="Default game version" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Select which game version is selected by default when the app opens."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,50,0" />
                                </StackPanel>

                                <ComboBox x:Name="DefaultGameVersionDropdown"
                                          Grid.Column="1"
                                          Width="150"
                                          Height="35"
                                          mah:ControlsHelper.CornerRadius="2"
                                          Background="{DynamicResource PrimaryAccent.Brush.W500}"
                                          BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                                          Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                          VerticalAlignment="Center"
                                          BorderThickness="1"
                                          VerticalContentAlignment="Center"
                                          SelectionChanged="DefaultGameVersionDropdown_SelectionChanged"
                                          mah:TextBoxHelper.Watermark="Select Version...">

                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Border.MouseOver" Color="{DynamicResource MahApps.Colors.Accent2}" />
                                        <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Border.Focus" Color="{DynamicResource MahApps.Colors.Accent3}" />
                                        <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.PopupBorder" Color="{DynamicResource MahApps.Colors.Accent3}" />
                                        <SolidColorBrush x:Key="MahApps.Brushes.Gray1" Color="{StaticResource MahApps.Colors.Accent}" />
                                        <SolidColorBrush x:Key="MahApps.Brushes.Gray5" Color="{StaticResource MahApps.Colors.Accent3}" />
                                    </ComboBox.Resources>

                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>

                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                            <Setter Property="Tag" Value="InDropDown" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ComboBox.ItemContainerStyle>

                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="VersionPill"
                                                    BorderBrush="{DynamicResource Alr.Brushes.GreenBase}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8,2,8,2"
                                                    Background="{DynamicResource Alr.Brushes.Green20}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SecondaryAccent.Brush.WA100}" />
                                            </Border>

                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ComboBoxItem}}, Path=Tag}" Value="InDropDown">
                                                    <Setter TargetName="VersionPill" Property="Background" Value="#33888888" />
                                                    <Setter TargetName="VersionPill" Property="BorderBrush" Value="#66888888" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <!-- Safe Mode -->
                            <Grid Grid.Row="3" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,50,0">
                                    <TextBlock Text="Safe mode" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Only download stable mod releases and ignore pre-release versions. Enabling this filters out development and release candidate builds (e.g., 3.2.1-dev.1 or 1.2.3-rc.3)."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,150,0" />
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1" x:Name="SafeModeToggle"
                                                  Header="" OnContent="" OffContent=""
                                                  Margin="0,0,-100,0"
                                                  HorizontalAlignment="Right"
                                                  Toggled="SafeModeToggle_Toggled"
                                                  Style="{StaticResource MahApps.Styles.ToggleSwitch}"
                                                  VerticalAlignment="Center" />
                            </Grid>

                            <Separator Grid.Row="4" Background="{StaticResource MahApps.Brushes.Accent3}" Margin="0,10,0,20" />

                            <!-- Check for Updates on Startup -->
                            <Grid Grid.Row="5" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,50,0">
                                    <TextBlock Text="Check for updates on startup" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Keep the application up to date by checking for updates on startup."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,150,0" />
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1" x:Name="CheckAppUpdatesToggle"
                                                  Header="" OnContent="" OffContent=""
                                                  Margin="0,0,-100,0"
                                                  HorizontalAlignment="Right"
                                                  Toggled="CheckAppUpdatesToggle_Toggled"
                                                  Style="{StaticResource MahApps.Styles.ToggleSwitch}"
                                                  VerticalAlignment="Center" />
                            </Grid>

                            <!-- Check for Updates Button -->
                            <Grid Grid.Row="6" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,50,0">
                                    <TextBlock Text="Check for updates" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Manually check for the latest version immediately."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,200,0" />
                                </StackPanel>

                                <Button x:Name="CheckAppUpdatesButton"
                                            Width="180"
                                            Height="35"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0 0 0 0"
                                            Click="CheckForUpdates_Click">

                                    <Button.Resources>
                                        <SolidColorBrush x:Key="MahApps.Brushes.Gray10" Color="{StaticResource PrimaryAccent.Colors.Accent}" />
                                        <SolidColorBrush x:Key="MahApps.Brushes.Gray8" Color="{StaticResource MahApps.Colors.Accent4}" />
                                    </Button.Resources>

                                    <Grid HorizontalAlignment="Stretch" Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <iconPacks:PackIconMaterial Kind="Update"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                        Width="18"
                                                                        Height="18"
                                                                        VerticalAlignment="Center"
                                                                        Margin="10,0,0,0"
                                                                        Grid.Column="0" />

                                        <TextBlock Text="Check for Updates"
                                                       Foreground="{DynamicResource SecondaryAccent.Brush.WA100}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Grid.Column="1"
                                                       Margin="0,0,18,0" />
                                    </Grid>
                                </Button>
                            </Grid>

                            <Separator Grid.Row="7" Background="{StaticResource MahApps.Brushes.Accent3}" Margin="0,10,0,20" />

                            <!-- Appearance Section -->
                            <TextBlock Grid.Row="8" Text="Appearance" Foreground="{DynamicResource DarkOlive.Brush.WA700}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15" />

                            <!-- Show ignore column in table -->
                            <Grid Grid.Row="9" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Display ignore column" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Show/hide the ignore column in the table."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,150,0" />
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1" x:Name="ShowIgnoreToggle"
                                                  Header="" OnContent="" OffContent=""
                                                  Margin="0,0,-100,0"
                                                  HorizontalAlignment="Right"
                                                  Toggled="ShowIgnoreToggle_Toggled"
                                                  Style="{StaticResource MahApps.Styles.ToggleSwitch}"
                                                  VerticalAlignment="Center" />
                            </Grid>

                            <!-- Show mod page column in table -->
                            <Grid Grid.Row="10" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Display mod page column" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Show/hide the mod page column in the table."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,150,0" />
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1" x:Name="ShowModPagesToggle"
                                                  Header="" OnContent="" OffContent=""
                                                  Margin="0,0,-100,0"
                                                  HorizontalAlignment="Right"
                                                  Toggled="ShowModPagesToggle_Toggled"
                                                  Style="{StaticResource MahApps.Styles.ToggleSwitch}"
                                                  VerticalAlignment="Center" />
                            </Grid>

                            <!-- Show file name column in table -->
                            <Grid Grid.Row="11" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Display file name column" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Show/hide the file name column in the table."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,150,0" />
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1" x:Name="ShowFileNamesToggle"
                                                  Header="" OnContent="" OffContent=""
                                                  Margin="0,0,-100,0"
                                                  HorizontalAlignment="Right"
                                                  Toggled="ShowFileNamesToggle_Toggled"
                                                  Style="{StaticResource MahApps.Styles.ToggleSwitch}"
                                                  VerticalAlignment="Center" />
                            </Grid>

                            <!-- Show game version column in table -->
                            <Grid Grid.Row="12" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Display game version column" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}" FontSize="14" />
                                    <TextBlock Text="Show/hide the game version column in the table."
                                               Foreground="{DynamicResource SecondaryAccent.Brush.WA700}" FontSize="12" TextWrapping="Wrap" Padding="0,0,150,0" />
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1" x:Name="ShowGameVersionToggle"
                                                  Header="" OnContent="" OffContent=""
                                                  Margin="0,0,-100,0"
                                                  HorizontalAlignment="Right"
                                                  Toggled="ShowGameVersionToggle_Toggled"
                                                  Style="{StaticResource MahApps.Styles.ToggleSwitch}"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <!-- App Settings Flyout Footer -->
                    <Border Grid.Row="1" Background="{StaticResource PrimaryAccent.Brush.W700}" BorderBrush="{StaticResource MahApps.Brushes.Accent3}" BorderThickness="0 1 0 0" Padding="15">
                        <!-- Tips Paragraph -->
                        <TextBlock Grid.Row="1"
                                   Foreground="{DynamicResource SecondaryAccent.Brush.WA400.O80}"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   Margin="0,0,0,0"
                                   Text="Your changes are saved automatically." />
                    </Border>
                </Grid>
            </mah:Flyout>

            <!-- Changelog Flyout -->
            <mah:Flyout x:Name="ChangelogFlyout"
                        Header="Changelog"
                        Position="Left"
                        Width="1293"
                        Foreground="{DynamicResource SecondaryAccent.Brush.WA200}"
                        Background="{StaticResource PrimaryAccent.Brush.W500}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                        BorderThickness="0 0 1 0"
                        IsOpen="{Binding IsChangelogFlyoutOpen}"
                        IsOpenChanged="ChangelogFlyout_IsOpenChanged">

                <mah:Flyout.Resources>
                    <SolidColorBrush x:Key="MahApps.Brushes.Gray3" Color="{DynamicResource MahApps.Colors.Accent3}" />
                    <SolidColorBrush x:Key="MahApps.Brushes.Thumb" Color="{DynamicResource MahApps.Colors.Accent2}" />

                    <Style TargetType="{x:Type ScrollViewer}" BasedOn="{StaticResource MahApps.Styles.ScrollViewer}">
                        <Style.Resources>
                            <SolidColorBrush x:Key="MahApps.Brushes.Gray3" Color="{DynamicResource MahApps.Colors.Accent3}" />
                            <SolidColorBrush x:Key="MahApps.Brushes.Thumb" Color="{DynamicResource MahApps.Colors.Accent2}" />
                        </Style.Resources>
                    </Style>
                </mah:Flyout.Resources>

                <Grid Margin="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <md:MarkdownScrollViewer x:Name="ChangelogRender"
                                     MarkdownStyle="{Binding ElementName=root, Path=MarkdownStyle}"
                                     HorizontalAlignment="Stretch">
                        </md:MarkdownScrollViewer>
                    </ScrollViewer>
                </Grid>
            </mah:Flyout>

