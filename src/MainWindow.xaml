                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Grid.Column="1"
                                                       Margin="0,0,18,0" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </mah:Flyout>

            <!-- Tips Flyout -->
            <mah:Flyout x:Name="TipsFlyout"
                        Header="Leave a Tip"
