                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <iconPacks:PackIconMaterial Kind="TrashCan"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Accent3}"
