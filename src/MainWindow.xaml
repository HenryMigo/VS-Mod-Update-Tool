                                    <iconPacks:PackIconMaterial.ToolTip>
                                        <TextBlock>
                                            <Run Text="Home" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                            <LineBreak />
                                            <Run Text="Navigate straight back to the Vintage Story Mod Database index page." />
                                        </TextBlock>
                                    </iconPacks:PackIconMaterial.ToolTip>
                                </iconPacks:PackIconMaterial>
                            </Button>

                            <Border Grid.Column="3"
                                    Background="{DynamicResource PrimaryAccent.Brush.W500}"
                                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Height="35">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <iconPacks:PackIconMaterial Kind="Earth"
                                                                Width="14" Height="14"
                                                                Grid.Column="0"
                                                                Foreground="{DynamicResource MahApps.Brushes.Accent3}"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />

                                    <TextBox x:Name="BrowserAddressBar"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             TextAlignment="Left"
                                             Foreground="{DynamicResource SecondaryAccent.Brush.WA400}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Margin="8,0,5,0"
                                             IsReadOnly="True"
                                             Text="{x:Static local:MainWindow.VSModRepoHomeUrl}"
                                             KeyDown="BrowserAddressBar_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">
                                        <Button x:Name="BrowserRefreshButton"
                                                Click="BrowserRefreshButton_Click"
                                                Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                                Padding="4"
                                                Height="26" Width="26">
                                            <iconPacks:PackIconMaterial Width="16" Height="16" Kind="Refresh" Foreground="{DynamicResource SecondaryAccent.Brush.WA200}">
                                                <iconPacks:PackIconMaterial.ToolTip>
                                                    <TextBlock>
                                                        <Run Text="Reload" Foreground="{DynamicResource MahApps.Brushes.Gray.SemiTransparent}" />
                                                    </TextBlock>
                                                </iconPacks:PackIconMaterial.ToolTip>
                                            </iconPacks:PackIconMaterial>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Separator Grid.Row="2" Background="{StaticResource MahApps.Brushes.Accent3}" Margin="0,10,0,10" />
                    </Grid>

                    <Border BorderBrush="{DynamicResource MahApps.Brushes.Accent3}" BorderThickness="2" Grid.Row="1" Margin="20,0,20,20">
                        <wv2:WebView2 x:Name="ModWebView" NavigationCompleted="WebView_NavigationCompleted" />
                    </Border>
                </Grid>
            </mah:Flyout>
        </mah:FlyoutsControl>
    </mah:MetroWindow.Flyouts>
</mah:MetroWindow>